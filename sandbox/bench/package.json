{
  "name": "celery-env-bench",
  "private": true,
  "type": "module",
  "scripts": {
    "bench": "node bench.mjs",
    "bool-shapes": "node bool-shapes.mjs",
    "cold": "node cold.mjs",
    "cold-first": "node cold-first-validate.mjs",
    "cold-modes": "node cold-modes.mjs",
    "enum": "node enum.mjs",
    "enum-list": "node enum-list.mjs",
    "enum-list-segment": "node enum-list-segment.mjs",
    "fail-fast": "node fail-fast.mjs",
    "generated-size": "node generated-size.mjs",
    "generated-shapes": "node generated-shapes.mjs",
    "json-invalid-fast-reject": "node json-invalid-fast-reject.mjs",
    "real-schemas": "node real-schemas.mjs",
    "report": "node report.mjs",
    "report:full": "node report.mjs --time 750 --warmup 250 --cold-runs 11",
    "parity": "node parity.mjs --runtimes node,bun",
    "process-env-generated-shapes": "node process-env-generated-shapes.mjs",
    "process-env-shapes": "node process-env-shapes.mjs",
    "runtime-matrix": "node runtime-matrix.mjs --runtimes node,bun",
    "repeat": "node repeat.mjs",
    "check": "BENCH_TIME=100 BENCH_WARMUP=50 node bench.mjs --artifact-out artifacts/current.json && node compare.mjs artifacts/check.json artifacts/current.json",
    "check:extended": "BENCH_TIME=100 BENCH_WARMUP=50 node list-variants.mjs --artifact-out artifacts/list-variants.current.json && RUNS=5 node cold-modes.mjs --artifact-out artifacts/cold-modes.current.json && node verify-extra.mjs artifacts/list-variants.current.json artifacts/cold-modes.current.json",
    "check:all": "npm run check && npm run check:extended",
    "check:release": "npm run check:all && npm run shipped-size && BENCH_TIME=100 BENCH_WARMUP=50 npm run fail-fast && BENCH_TIME=100 BENCH_WARMUP=50 npm run real-schemas && npm run report",
    "list": "node list.mjs",
    "list-url-trim-bounds": "node list-url-trim-bounds.mjs",
    "list-variants": "node list-variants.mjs",
    "missing-defaults": "node missing-defaults.mjs",
    "runtime-list-scan": "node runtime-list-scan.mjs",
    "scan": "node scan-experiments.mjs",
    "shipped-size": "node shipped-size.mjs",
    "split-cold": "node split-cold.mjs",
    "split-large": "node split-large.mjs",
    "split-v2": "node split-v2.mjs",
    "strict-num-list-segment": "node strict-num-list-segment.mjs",
    "strict-numeric": "node strict-numeric.mjs",
    "string-cache": "node string-cache.mjs"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "convict": "^6.2.5",
    "dotenv-extended": "^3.1.0",
    "dotenv-safe": "^9.1.0",
    "env-schema": "^7.0.0",
    "env-type-validator": "^1.0.1",
    "env-var": "^7.5.0",
    "envalid": "8.2.0",
    "envsafe": "2.0.3",
    "esbuild": "^0.28.1",
    "lazy-strict-env": "^0.3.1",
    "safe-env-vars": "^1.0.8",
    "tinybench": "6.0.2",
    "valibot": "1.4.1",
    "valid-env": "^1.1.1",
    "valienv": "^1.1.0",
    "zod": "4.4.3"
  }
}
