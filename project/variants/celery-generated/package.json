{
  "name": "celery-migration-fixture-celery-generated",
  "version": "0.0.0",
  "private": true,
  "description": "A realistic pre-Celery Node service used to measure env-validation migration effort.",
  "type": "module",
  "scripts": {
    "generate": "node ../../../src/cli.js --schema env.schema.mjs --out src/env.mjs --types src/env.d.ts --example .env.example --optimize speed --force",
    "start": "node src/server.js",
    "worker": "node src/worker.js",
    "test": "node --test test/*.mjs",
    "audit:env": "node scripts/audit-env-reads.mjs"
  },
  "devDependencies": {
    "celery-env": "file:../../.."
  },
  "engines": {
    "node": ">=20"
  }
}
