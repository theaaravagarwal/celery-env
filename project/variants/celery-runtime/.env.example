# Current runtime environment.
NODE_ENV=development

APP_NAME=orders-api

HOST=127.0.0.1

PORT=3000

# Conditionally required
# Development default: http://localhost:3000
PUBLIC_URL=http://localhost:3000

TRUST_PROXY=false

SUPPORT_EMAIL=support@example.com

DATABASE_URL=

DATABASE_POOL_MIN=1

DATABASE_POOL_MAX=10

# Optional
REDIS_URL=

LOG_LEVEL=info

# Development default: pretty
LOG_FORMAT=json

OTEL_ENABLED=false

# Optional
SENTRY_DSN=

CORS_ORIGINS=http://localhost:5173

RATE_LIMIT_JSON={"windowMs":60000,"max":120}

FEATURE_FLAGS=

ALLOWED_TENANTS=demo

PAYMENTS_PROVIDER=mock

# Optional
# Conditionally required
STRIPE_SECRET_KEY=

# Optional
WEBHOOK_ENDPOINT=

WORKER_CONCURRENCY=4

JOB_QUEUES=email,billing,reports

ENABLE_SIGNUPS=true

# Conditionally required
# Development default: development-only-session-secret-value
SESSION_SECRET=development-only-session-secret-value
