NODE_ENV=development
APP_NAME=orders-api
HOST=127.0.0.1
PORT=3000
PUBLIC_URL=http://localhost:3000

DATABASE_URL=postgres://user:pass@localhost:5432/orders
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=10
REDIS_URL=redis://localhost:6379

LOG_LEVEL=info
LOG_FORMAT=pretty
OTEL_ENABLED=false
SENTRY_DSN=

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
RATE_LIMIT_JSON={"windowMs":60000,"max":120}
FEATURE_FLAGS=checkout-v2,invoice-export
ALLOWED_TENANTS=demo,internal

PAYMENTS_PROVIDER=mock
STRIPE_SECRET_KEY=
WEBHOOK_ENDPOINT=http://localhost:3000/webhooks/payments

WORKER_CONCURRENCY=4
JOB_QUEUES=email,billing,reports
ENABLE_SIGNUPS=true
TRUST_PROXY=false
SESSION_SECRET=development-only-session-secret
SUPPORT_EMAIL=support@example.com
